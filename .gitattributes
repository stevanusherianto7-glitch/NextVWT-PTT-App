# Normalize line endings to LF in the repo so CI (Linux) and prettier agree.
# Windows checkouts may still use CRLF locally, but the stored blob is LF.
* text=auto eol=lf

*.ts text
*.tsx text
*.js text
*.jsx text
*.json text
*.md text
*.css text
*.yml text
*.yaml text

# Binary / non-text — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.apk binary
*.keystore binary
