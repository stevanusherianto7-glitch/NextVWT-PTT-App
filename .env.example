# NextVWT PTT App - Environment Variables Template
# Copy this file to '.env' and fill in the values.

# Supabase API Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-sb-publishable-key-here

# Google OAuth Configuration
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# WebRTC TURN Server Configuration (Biznet Gio TURN / Coturn for Indonesian Mobile Operators)
# Format URL: turn:<ip-or-domain>:3478?transport=udp (or turns:...:5349 for TLS)
# Relays WebRTC audio traffic reliably across mobile carriers (Telkomsel, Indosat, XL) through symmetric NATs.
VITE_TURN_URL=turn:turn.biznetgio.com:3478?transport=udp
VITE_TURN_USERNAME=your-turn-username
VITE_TURN_CREDENTIAL=your-turn-credential
